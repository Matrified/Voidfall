# Copy to .env and adjust. All variables are prefixed with VOIDFALL_.

# development | production | test
VOIDFALL_ENVIRONMENT=development

# SQLite for local dev; PostgreSQL in production, e.g.
#   postgresql+psycopg://voidfall:voidfall@db:5432/voidfall
VOIDFALL_DATABASE_URL=sqlite:///./voidfall.db

# REQUIRED in production. Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
VOIDFALL_JWT_SECRET=dev-only-insecure-secret-change-me
VOIDFALL_JWT_ALGORITHM=HS256
VOIDFALL_JWT_TTL_SECONDS=3600

# Comma-separated list is also accepted via JSON, e.g. ["https://play.example.com"]
# VOIDFALL_CORS_ORIGINS=["http://localhost:5173"]

VOIDFALL_DEFAULT_SEED=1337

# --- LLM narration (optional) ----------------------------------------------
# The game is fully playable with no LLM (engine-authored fallback). Set a provider
# to unlock rich, free-form narration and occasional AI scene art.
#
# provider: none | openai | gemini | ollama
VOIDFALL_LLM_PROVIDER=none
# Model (leave blank for the provider default):
#   openai -> gpt-4o-mini | gemini -> gemini-2.0-flash | ollama -> llama3.1
VOIDFALL_LLM_MODEL=
# Put your key here, OR export the conventional env var (OPENAI_API_KEY / GOOGLE_API_KEY).
VOIDFALL_LLM_API_KEY=
# Override the endpoint for OpenAI-compatible gateways or a remote Ollama:
VOIDFALL_LLM_BASE_URL=
VOIDFALL_LLM_TIMEOUT_SECONDS=12

# --- To use Google Gemini's free tier (recommended) ------------------------
# 1. Get a key at https://aistudio.google.com/apikey
# 2. Set:
#      VOIDFALL_LLM_PROVIDER=gemini
#      VOIDFALL_LLM_API_KEY=<your key>
# 3. Restart the backend.
